#!/bin/bash
# Snapcraft "Hold" Editor
# This script saves the temp file for external editing and waits for confirmation

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TEMP_FILE="$1"
HOLD_DIR="${SNAPCRAFT_HOLD_DIR:-$HOME/.snapcraft-hold}"
HOLD_FILE="$HOLD_DIR/confdb-schema-edit.yaml"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Create hold directory
mkdir -p "$HOLD_DIR"

# Extract metadata for informative messages
ACCOUNT_ID=$(grep '^account-id:' "$TEMP_FILE" | awk '{print $2}')
NAME=$(grep '^name:' "$TEMP_FILE" | awk '{print $2}')

# Save the original file
cp "$TEMP_FILE" "$HOLD_FILE"

# Also save a timestamped backup
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
BACKUP_FILE="$HOLD_DIR/backup-${ACCOUNT_ID:-unknown}-${NAME:-unknown}-${TIMESTAMP}.yaml"
cp "$TEMP_FILE" "$BACKUP_FILE"

echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}  Snapcraft Confdb Schema - External Edit Mode${NC}"
echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
echo
echo -e "${BLUE}Schema Details:${NC}"
echo -e "  Account ID: ${YELLOW}${ACCOUNT_ID}${NC}"
echo -e "  Name:       ${YELLOW}${NAME}${NC}"
echo
echo -e "${BLUE}File Locations:${NC}"
echo -e "  Working file: ${YELLOW}${HOLD_FILE}${NC}"
echo -e "  Backup:       ${YELLOW}${BACKUP_FILE}${NC}"
echo
echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
echo
echo -e "${YELLOW}Instructions:${NC}"
echo "  1. The schema has been saved to: $HOLD_FILE"
echo "  2. Edit it with your preferred tools in another terminal"
echo "  3. When ready, press ENTER here to continue"
echo "  4. Or press Ctrl+C to abort without changes"
echo
echo -e "${BLUE}Useful commands in another terminal:${NC}"
echo -e "  ${GREEN}# Edit the file${NC}"
echo "  vim $HOLD_FILE"
echo
echo -e "  ${GREEN}# EASY WAY: Automatic sign & ack (auto-bumps revision)${NC}"
echo "  $SCRIPT_DIR/snapcraft-sign-and-ack -k <key-name>"
echo
echo -e "  ${GREEN}# MANUAL WAY: Convert, sign, and ack step by step${NC}"
echo "  $SCRIPT_DIR/yaml-to-sign-json.py $HOLD_FILE > /tmp/schema.json"
echo "  cat /tmp/schema.json | snap sign -k <key> > /tmp/schema.assert"
echo "  snap ack /tmp/schema.assert"
echo
echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"

# Launch real editor if specified
if [ -n "$REAL_EDITOR" ]; then
    echo
    echo -e "${BLUE}Launching editor: ${YELLOW}${REAL_EDITOR}${NC}"
    echo
    $REAL_EDITOR "$HOLD_FILE"
fi

echo
echo -n "Press ENTER when you've finished editing (or Ctrl+C to abort)... "

# Wait for user confirmation
read -r

# Check if file was modified
if [ -f "$HOLD_FILE" ]; then
    # Copy the edited version back to the temp file
    cp "$HOLD_FILE" "$TEMP_FILE"
    
    echo ""
    echo -e "${GREEN}✓ Changes loaded from $HOLD_FILE${NC}"
    echo -e "${GREEN}✓ Returning to snapcraft...${NC}"
    echo ""
else
    echo ""
    echo -e "${RED}✗ Hold file not found!${NC}"
    echo -e "${RED}✗ No changes will be made.${NC}"
    echo ""
fi

exit 0
